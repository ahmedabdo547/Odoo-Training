<odoo>
    <record id="view_order_form_with_color_picker" model="ir.ui.view">
        <field name="name">sale.order.form.view.with_color_picker</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group/group[1]" position="inside">
                <field name="color_number" widget="owl_color_picker"/>
            </xpath>
        </field>
    </record>
</odoo>